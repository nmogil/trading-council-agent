# Runtime
TRADING_COUNCIL_MODE=paper
TRADING_COUNCIL_LIVE_ENABLED=false
TRADING_COUNCIL_KILL_SWITCH=false
TRADING_COUNCIL_DATABASE_URL=sqlite:///./data/trading_council.db
TRADING_COUNCIL_TIMEZONE=Europe/London

# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
DISCORD_ADMIN_USER_IDS=

# Alpaca paper
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Research agent (LLM brief). Missing keys disable that source; web search needs only Anthropic.
ANTHROPIC_API_KEY=
TRADING_COUNCIL_RESEARCH_MODEL=claude-opus-4-8
FINANCIAL_DATASETS_API_KEY=

# Alpaca live — leave unset until a later phase enables live trading
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
